# =============================================
# JCE-Citizen-Backend Environment Configuration
# =============================================

# Server Ports
APP_PORT_EXTERNAL=8080
DB_PORT_EXTERNAL=3306
REDIS_PORT_EXTERNAL=6379

# Database Configuration
DB_HOST=jce-mysql
DB_PORT=3306
DB_NAME=jce_consulta_db
DB_USER=jce_user
DB_PASSWORD=jce_password_secure
DB_ROOT_PASSWORD=jce_root_password_secure

# Redis Configuration
REDIS_HOST=jce-redis
REDIS_PORT=6379

# JWT Security
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters_long
JWT_EXPIRATION=86400000

# Spring Boot Profiles
SPRING_PROFILES_ACTIVE=prod
